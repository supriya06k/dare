PORT=8080
DATABASE_URL=postgres://dare:dare@localhost:5432/dare?sslmode=disable
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-min-32-chars

# Firebase Admin SDK — download from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS_FILE=./firebase-credentials.json

# Cloudflare R2
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=dare-proofs
AWS_ACCESS_KEY_ID=<r2-access-key-id>
AWS_SECRET_ACCESS_KEY=<r2-secret-access-key>

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# AI Screener worker (internal)
AI_SCREENER_URL=http://localhost:8001
